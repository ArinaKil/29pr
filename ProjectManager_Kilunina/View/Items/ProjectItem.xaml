<UserControl x:Class="ProjectManager_Kilunina.View.Items.ProjectItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ProjectManager_Kilunina.View.Items"
             mc:Ignorable="d"
             FontFamily="Bahnschrift Light Condensed">
    <UserControl.Resources>
        <Style TargetType="Button" x:Key="Open">
            <Setter Property="Background" Value="#FF1B8FD6"/>
            <Setter Property="BorderBrush" Value="#FF1B8FD6"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="Button" x:Key="Update">
            <Setter Property="Background" Value="#FF2DD61B"/>
            <Setter Property="BorderBrush" Value="#FF2DD61B"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="Button" x:Key="Delete">
            <Setter Property="Background" Value="#FFD62F1B"/>
            <Setter Property="BorderBrush" Value="#FFD62F1B"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10" Background="White">
        <Grid.Effect>
            <DropShadowEffect Opacity="0.1"/>
        </Grid.Effect>
        <Image Width="40" Height="40" Margin="10" VerticalAlignment="Top" HorizontalAlignment="Left"
               Source="/Images/ic_project.png"/>
        <Grid Margin="60, 0, 0, 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="270"/>
            </Grid.ColumnDefinitions>
            <Grid Margin="10" Height="60" VerticalAlignment="Top" Background="White">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Название проекта:" VerticalAlignment="Top" Margin="10, 0, 10, 0"/>
                <TextBox
                    Text="{Binding Name}"
                    IsEnabled="{Binding IsEnable}"
                    VerticalContentAlignment="Center"
                    Margin="10, 25, 10, 0"
                    VerticalAlignment="Top"
                    Height="25"/>
            </Grid>
            <Grid Margin="10, 80, 10, 0" Height="60" VerticalAlignment="Top" Background="White">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Заказчик:" VerticalAlignment="Top" Margin="10, 0, 10, 0"/>
                <TextBox
                    Text="{Binding Customer}"
                    IsEnabled="{Binding IsEnable}"
                    VerticalContentAlignment="Center"
                    Margin="10, 25, 10, 0"
                    VerticalAlignment="Top"
                    Height="25"/>
            </Grid>
            <Grid Margin="10,10,10,0" Height="60" VerticalAlignment="Top" Background="White" Grid.Column="1">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Срок сдачи:" VerticalAlignment="Top" Margin="10, 0, 10, 0"/>
                <DatePicker
                    SelectedDate="{Binding DateEnd}"
                    IsEnabled="{Binding IsEnable}"
                    Margin="10, 25, 10, 0"
                    VerticalAlignment="Top"
                    Height="25"/>
            </Grid>
            <Grid Margin="10,80,10,0" Height="60" VerticalAlignment="Top" Background="White" Grid.Column="1">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Статус:" VerticalAlignment="Top" Margin="10, 0, 10, 0"/>
                <ComboBox
                    ItemsSource="{Binding Statuses}"
                    SelectedItem="{Binding StatusText, Mode=TwoWay}"
                    IsEnabled="{Binding IsEnable}"
                    VerticalContentAlignment="Center"
                    Margin="10, 25, 10, 0"
                    VerticalAlignment="Top"
                    Height="25"/>
            </Grid>
            <Button Style="{StaticResource Open}"
                    Command="{Binding OnOpen}"
                    Content="Открыть"
                    Height="25"
                    Width="70"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Margin="0,10,10,0"
                    Grid.Column="1">
                <Button.Effect>
                    <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"></DropShadowEffect>
                </Button.Effect>
            </Button>
            <Button Style="{StaticResource Update}"
                    Command="{Binding OnEdit}"
                    Content="{Binding IsEnableText}"
                    Height="25"
                    Width="70"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Margin="0,145,85,0"
                    Grid.Column="1">
                <Button.Effect>
                    <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"></DropShadowEffect>
                </Button.Effect>
            </Button>
            <Button Style="{StaticResource Delete}"
                    Command="{Binding OnDelete}"
                    Content="Удалить"
                    Height="25"
                    Width="70"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Margin="0,145,10,0"
                    Grid.Column="1">
                <Button.Effect>
                    <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"></DropShadowEffect>
                </Button.Effect>
            </Button>
        </Grid>
    </Grid>
</UserControl>
