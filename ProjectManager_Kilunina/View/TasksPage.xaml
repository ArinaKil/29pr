<Page x:Class="ProjectManager_Kilunina.View.TasksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:elements="clr-namespace:ProjectManager_Kilunina.View.Items"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="TasksPage">
    <Page.Resources>
        <Style TargetType="Button" x:Key="Update">
            <Setter Property="Background" Value="#FF2DD61B"/>
            <Setter Property="BorderBrush" Value="#FF2DD61B"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="Button" x:Key="Back">
            <Setter Property="Background" Value="#FF808080"/>
            <Setter Property="BorderBrush" Value="#FF808080"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid Height="35" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Style="{StaticResource Back}"
                    Command="{Binding OnBack}"
                    Content="← Назад"
                    Height="25"
                    Width="80"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Margin="10,0,0,0">
                <Button.Effect>
                    <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"></DropShadowEffect>
                </Button.Effect>
            </Button>
            <Label Grid.Column="1" Content="{Binding Project.Name}" FontSize="16"
                   VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
        </Grid>

        <ListView ItemsSource="{Binding Tasks}" HorizontalContentAlignment="Stretch" Margin="0,40,0,45">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <elements:Item DataContext="{Binding}"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Button Style="{StaticResource Update}"
                Command="{Binding OnAddTask}"
                Content="Добавить"
                Height="25"
                Width="70"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Margin="0,0,10,10">
            <Button.Effect>
                <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"></DropShadowEffect>
            </Button.Effect>
        </Button>
    </Grid>
</Page>
